# Gaialangit ERP Environment Configuration
# Copy to .env and adjust values

# ─── Odoo Version Pin ───
# After Phase 0 smoke test, lock the exact image tag here.
# Options:
#   odoo:18.0          (stable fallback)
#   odoo:19.0          (if nightly is stable — test first)
#   odoo:nightly       (latest nightly — not recommended for production)
ODOO_IMAGE=odoo:18.0

# ─── Ports ───
ODOO_PORT=8069
PG_PORT=5432

# ─── Database ───
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo

# ─── Odoo Database Name ───
# The main application database
ODOO_DB=gaialangit
