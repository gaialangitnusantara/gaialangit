<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_agri_division_list" model="ir.ui.view">
        <field name="name">agri.division.list</field>
        <field name="model">agri.division</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_agri_division_form" model="ir.ui.view">
        <field name="name">agri.division.form</field>
        <field name="model">agri.division</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Identification">
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group string="Status">
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="sites" string="Sites">
                            <field name="site_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="city"/>
                                    <field name="active" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_agri_division" model="ir.actions.act_window">
        <field name="name">Divisions</field>
        <field name="res_model">agri.division</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
