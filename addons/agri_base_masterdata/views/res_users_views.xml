<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Inherit the standard user form to add Farm Access fields.
        Verified: base.view_users_form exists in Odoo 19.
        Verified: //page[@name='preferences'] exists in Odoo 19 user form.
        XPath: add new page after the Preferences tab.
    -->
    <record id="view_res_users_form_farm_access" model="ir.ui.view">
        <field name="name">res.users.form.farm.access</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page name="farm_access" string="Farm Access"
                      groups="agri_base_masterdata.group_farm_admin">
                    <group>
                        <field name="site_id"
                               help="Assign one site to this shed manager (1:1)."/>
                        <field name="zone_ids" widget="many2many_tags"
                               help="Assign zones to this operator."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
