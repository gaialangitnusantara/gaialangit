<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_agri_site_list" model="ir.ui.view">
        <field name="name">agri.site.list</field>
        <field name="model">agri.site</field>
        <field name="arch" type="xml">
            <list>
                <field name="division_id"/>
                <field name="name"/>
                <field name="city"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_agri_site_form" model="ir.ui.view">
        <field name="name">agri.site.form</field>
        <field name="model">agri.site</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Identification">
                            <field name="name"/>
                            <field name="division_id"/>
                        </group>
                        <group string="Status">
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Address">
                        <field name="street"/>
                        <field name="city"/>
                        <field name="zip"/>
                        <field name="country_id"/>
                    </group>
                    <notebook>
                        <page name="zones" string="Zones">
                            <field name="zone_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="zone_type"/>
                                    <field name="capacity"/>
                                    <field name="active" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_agri_site" model="ir.actions.act_window">
        <field name="name">Sites</field>
        <field name="res_model">agri.site</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
