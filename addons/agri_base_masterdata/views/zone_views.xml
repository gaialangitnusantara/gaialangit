<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_agri_zone_list" model="ir.ui.view">
        <field name="name">agri.zone.list</field>
        <field name="model">agri.zone</field>
        <field name="arch" type="xml">
            <list>
                <field name="division_id"/>
                <field name="site_id"/>
                <field name="name"/>
                <field name="zone_type"/>
                <field name="capacity"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_agri_zone_form" model="ir.ui.view">
        <field name="name">agri.zone.form</field>
        <field name="model">agri.zone</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Identification">
                            <field name="name"/>
                            <field name="zone_type"/>
                        </group>
                        <group string="Location">
                            <field name="division_id"/>
                            <field name="site_id"
                                   domain="[('division_id', '=', division_id)]"/>
                        </group>
                    </group>
                    <group string="Details">
                        <field name="capacity"/>
                        <field name="active"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_agri_zone" model="ir.actions.act_window">
        <field name="name">Zones</field>
        <field name="res_model">agri.zone</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
