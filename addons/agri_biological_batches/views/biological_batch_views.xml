<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_agri_bio_batch_list" model="ir.ui.view">
        <field name="name">agri.biological.batch.list</field>
        <field name="model">agri.biological.batch</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'closed'">
                <field name="name"/>
                <field name="batch_type"/>
                <field name="division_id"/>
                <field name="site_id"/>
                <field name="zone_id"/>
                <field name="start_date"/>
                <field name="initial_count"/>
                <field name="current_count"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('active', 'harvesting')"
                       decoration-success="state == 'closed'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="last_gate_sync" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_agri_bio_batch_form" model="ir.ui.view">
        <field name="name">agri.biological.batch.form</field>
        <field name="model">agri.biological.batch</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Activate"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start_harvesting" string="Start Harvesting"
                            type="object"
                            invisible="state != 'active'"/>
                    <button name="action_close" string="Close Batch"
                            type="object"
                            invisible="state not in ('active', 'harvesting')"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('closed', 'cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,harvesting,closed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Identification">
                            <field name="name"/>
                            <field name="batch_type"/>
                        </group>
                        <group string="Location">
                            <field name="division_id"/>
                            <field name="site_id"
                                   domain="[('division_id', '=', division_id)]"/>
                            <field name="zone_id"
                                   domain="[('site_id', '=', site_id)]"/>
                        </group>
                    </group>
                    <group>
                        <group string="Timeline">
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group string="Head Count">
                            <field name="initial_count"/>
                            <field name="current_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="sync" string="Stock Sync">
                            <group>
                                <field name="last_gate_sync" readonly="1"/>
                            </group>
                            <field name="stock_sync_display" readonly="1" nolabel="1" widget="html"/>
                        </page>
                        <page name="notes" string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_agri_bio_batch" model="ir.actions.act_window">
        <field name="name">Biological Batches</field>
        <field name="res_model">agri.biological.batch</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
