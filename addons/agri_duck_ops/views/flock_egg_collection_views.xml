<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_flock_egg_collection_list" model="ir.ui.view">
        <field name="name">agri.flock.egg.collection.list</field>
        <field name="model">agri.flock.egg.collection</field>
        <field name="arch" type="xml">
            <list string="Egg Collections">
                <field name="batch_id"/>
                <field name="date"/>
                <field name="quantity"/>
                <field name="grade"/>
                <field name="lot_id" optional="show" readonly="1"/>
                <field name="notes" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
                <button name="action_confirm"
                        string="Confirm"
                        type="object"
                        invisible="state != 'draft'"
                        icon="fa-check"/>
            </list>
        </field>
    </record>

    <record id="view_flock_egg_collection_form" model="ir.ui.view">
        <field name="name">agri.flock.egg.collection.form</field>
        <field name="model">agri.flock.egg.collection</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm"
                            string="Confirm Collection"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Confirm egg collection? Eggs will be received into finished goods stock with an auto-generated lot."/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Egg Collection">
                            <field name="batch_id"/>
                            <field name="date"/>
                            <field name="quantity"/>
                            <field name="grade"/>
                        </group>
                        <group string="Stock Move">
                            <field name="lot_id" readonly="1"/>
                            <field name="move_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes (optional)..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_agri_flock_egg_collection" model="ir.actions.act_window">
        <field name="name">Egg Collections</field>
        <field name="res_model">agri.flock.egg.collection</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
