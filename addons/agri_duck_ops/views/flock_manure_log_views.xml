<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_flock_manure_log_list" model="ir.ui.view">
        <field name="name">agri.flock.manure.log.list</field>
        <field name="model">agri.flock.manure.log</field>
        <field name="arch" type="xml">
            <list string="Manure Logs">
                <field name="batch_id"/>
                <field name="date"/>
                <field name="estimated_kg"/>
                <field name="lot_id" optional="show" readonly="1"/>
                <field name="notes" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
                <button name="action_confirm"
                        string="Confirm"
                        type="object"
                        invisible="state != 'draft'"
                        icon="fa-check"/>
            </list>
        </field>
    </record>

    <record id="view_flock_manure_log_form" model="ir.ui.view">
        <field name="name">agri.flock.manure.log.form</field>
        <field name="model">agri.flock.manure.log</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm"
                            string="Confirm Capture"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Confirm manure capture? Manure will be received into inventory with an auto-generated lot."/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Manure Capture">
                            <field name="batch_id"/>
                            <field name="date"/>
                            <field name="estimated_kg"/>
                        </group>
                        <group string="Stock Move">
                            <field name="lot_id" readonly="1"/>
                            <field name="move_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes (optional)..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_agri_flock_manure_log" model="ir.actions.act_window">
        <field name="name">Manure Logs</field>
        <field name="res_model">agri.flock.manure.log</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
