<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_flock_vaccine_log_list" model="ir.ui.view">
        <field name="name">agri.flock.vaccine.log.list</field>
        <field name="model">agri.flock.vaccine.log</field>
        <field name="arch" type="xml">
            <list string="Vaccine / Treatment Logs"
                  decoration-muted="state == 'confirmed'">
                <field name="date"/>
                <field name="batch_id"/>
                <field name="product_id"/>
                <field name="treatment_type"/>
                <field name="quantity"/>
                <field name="uom_id"/>
                <field name="lot_id" optional="show"/>
                <field name="notes" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
                <button name="action_confirm"
                        string="Confirm"
                        type="object"
                        invisible="state != 'draft'"
                        icon="fa-check"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_flock_vaccine_log_form" model="ir.ui.view">
        <field name="name">agri.flock.vaccine.log.form</field>
        <field name="model">agri.flock.vaccine.log</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Confirm treatment? This will create a stock move consuming the product from warehouse."/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Treatment">
                            <field name="batch_id"/>
                            <field name="date"/>
                            <field name="treatment_type"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                            <field name="lot_id"
                                   domain="[('product_id', '=', product_id)]"/>
                        </group>
                        <group string="Status">
                            <field name="state" readonly="1"/>
                            <field name="move_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_agri_flock_vaccine_log" model="ir.actions.act_window">
        <field name="name">Vaccine / Treatment Logs</field>
        <field name="res_model">agri.flock.vaccine.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

</odoo>
